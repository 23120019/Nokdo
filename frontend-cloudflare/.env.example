VITE_FIREBASE_API_BASE=https://<region>-<project-id>.cloudfunctions.net/api
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_AUTH_EMULATOR_URL=
# Optional: in development, empty means auto redirect to http://<current-host>:8501
VITE_POST_LOGIN_URL=
# true면 로그인 후 VITE_POST_LOGIN_URL로 자동 이동, false면 현재 페이지에 머무름
VITE_AUTO_REDIRECT_AFTER_LOGIN=false